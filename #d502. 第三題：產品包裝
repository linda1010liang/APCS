#d502. 第三題：產品包裝
while 1:
    try:
        a,b,c,d=map(int,input().split())#a:1cm物品 b:2物品 c:3物品 d:4物品
        box=0#箱子總數
        box+=d
        box+=c
        empty_space=(64-27)*c
        box=box+b//8
        if b%8!=0:
            box+=1
            empty_space+=(4*4*4)-(b%8)*(2*2*2)
        if empty_space>=a:
            print(box)
        else:
            a-=empty_space
            if a%64==0:
               box+=a//64
            else:
                box+=a//64+1
            print(box)
    except:
        break

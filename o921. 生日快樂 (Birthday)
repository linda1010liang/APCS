#o921. 生日快樂 (Birthday)
m,d=map(int,input().split())#當前的月和日
m1,d1=map(int,input().split())#生日的月和日
bm=[1,3,5,7,8,10,12]
sm=[4,6,9,11]
day1=0#當前天總數
for i in range(1,m):
    if i==2:
        day1+=28
    elif i in bm:
        day1+=31
    else:
        day1+=30
day1+=d
day2=0#生日天總數
for i in range(1,m1):
    if i==2:
        day2+=28
    elif i in bm:
        day2+=31
    else:
        day2+=30
day2+=d1
if day2<day1:
    day2+=365
print(day2-day1)
